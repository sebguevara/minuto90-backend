generator client {
  provider = "prisma-client"
  output   = "../prisma-minuto/minuto-client-types"
}

datasource db {
  provider = "postgresql"
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userAgent String?
  lastSeenAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([lastSeenAt])
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?
  firstName String?
  lastName  String?
  name      String?
  imageUrl  String?
  role      String   @default("user")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscribers         NotificationSubscriber[]
  news                News[]
  posts               Post[]
  favorites           Favorite[]
  pushSubscriptions   PushSubscription[]
  mundialPronostico   MundialPronostico?
}

// ─── Favorites ──────────────────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport      String
  entityType String
  entityId   Int
  metadata   Json
  createdAt  DateTime @default(now())

  @@unique([userId, sport, entityType, entityId])
  @@index([userId, sport])
}

model NotificationSubscriber {
  id                 String              @id @default(uuid())
  phoneNumber        String?             @unique
  name               String?
  countryCode        String?
  dialCode           String?
  nationalNumber     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  isActive           Boolean             @default(true)
  notifyPreMatch30m  Boolean             @default(true)
  notifyKickoff      Boolean             @default(true)
  notifyGoals        Boolean             @default(true)
  notifyRedCards     Boolean             @default(false)
  notifyVarCancelled Boolean             @default(false)
  notifyHalftime     Boolean             @default(false)
  notifySecondHalf   Boolean             @default(false)
  notifyFullTime     Boolean             @default(true)
  userId             String?             @unique
  user               User?               @relation(fields: [userId], references: [id])
  subscriptions      MatchSubscription[]

  @@index([userId])
}

model MatchSubscription {
  id           String                 @id @default(uuid())
  subscriberId String
  fixtureId    Int
  homeTeamId   Int?
  awayTeamId   Int?
  homeTeam     String
  awayTeam     String
  leagueName   String?
  matchDate    DateTime
  sourceType   String?
  sourceEntityId Int?
  subscriber   NotificationSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, fixtureId])
  @@index([fixtureId])
  @@index([subscriberId, sourceType, sourceEntityId])
}

model EvolutionInstance {
  id           String   @id @default(uuid())
  instanceName String   @unique
  baseUrl      String
  apiKey       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── News ────────────────────────────────────────────────────────────────────

model NewsCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  news News[]

  @@index([isActive, sortOrder])
}

model News {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  summary     String?
  body        String
  imageUrl    String?
  authorId    String?
  author      User?         @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    NewsCategory? @relation(fields: [categoryId], references: [id])
  authorName  String?
  featured    Boolean       @default(false)
  isHidden    Boolean       @default(false)
  isMundial   Boolean       @default(false)
  viewCount   Int           @default(0)
  clickCount  Int           @default(0)
  publishFrom DateTime?
  publishTo   DateTime?
  publishedAt DateTime      @default(now())
  pushSentAt  DateTime?
  isDeleted   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([publishedAt])
  @@index([pushSentAt])
  @@index([isDeleted, publishedAt])
  @@index([isHidden, publishedAt])
  @@index([featured, isDeleted])
  @@index([categoryId])
  @@index([viewCount])
  @@index([isMundial, publishedAt])

  tags NewsTag[]
}

model NewsTag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  news News[]

  @@index([slug])
}

// ─── Posts ───────────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  context   String?
  type      String?  @default("general")
  category  String?
  countryCode String?
  gallery   Json?
  displayOrder Int   @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDeleted, createdAt])
  @@index([context, createdAt])
  @@index([context, type, category, createdAt])
  @@index([countryCode, createdAt])
  @@index([displayOrder, createdAt])
}

// ─── Mundial 2026 ────────────────────────────────────────────────────────────

model MundialPronostico {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  bracket   Json
  score     Int       @default(0)
  isLocked  Boolean   @default(false)
  lockedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([score])
}

// ─── Fixture stats snapshots por período ─────────────────────────────────────
// Persistencia durable de estadísticas capturadas en hitos del partido:
// first-half-end, full-time-end, extra-first-half-end, final.
// Redis sigue siendo cache hot; esta tabla es la fuente de verdad.

model FixtureStatsPeriod {
  id         String   @id @default(cuid())
  fixtureId  Int
  snapshotId String
  teamId     Int
  teamName   String
  statistics Json
  capturedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fixtureId, snapshotId, teamId])
  @@index([fixtureId])
}

model FixturePlayerStatsPeriod {
  id         String   @id @default(cuid())
  fixtureId  Int
  snapshotId String
  teamId     Int
  playerId   Int
  playerName String
  statistics Json
  capturedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([fixtureId, snapshotId, playerId])
  @@index([fixtureId])
}

// Insights de momentum generados durante el partido.
// Se persisten para que sobrevivan a recargas/navegación y estén
// disponibles aunque el usuario entre después del live.
model MatchMomentumInsight {
  id          String   @id @default(cuid())
  fixtureId   Int
  minute      Int
  signalType  String
  team        String
  narrative   String
  cardTitle   String
  emoji       String
  stats       Json
  delta       Json
  probability Float?
  createdAt   DateTime @default(now())

  @@unique([fixtureId, signalType, team, minute])
  @@index([fixtureId, createdAt])
}
