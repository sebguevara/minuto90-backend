generator client {
  provider = "prisma-client"
  output   = "../prisma-minuto/minuto-client-types"
}

datasource db {
  provider = "postgresql"
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String?
  name      String?
  imageUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscribers NotificationSubscriber[]
  news        News[]
  posts       Post[]
}

model NotificationSubscriber {
  id            String              @id @default(uuid())
  phoneNumber   String              @unique
  name          String?
  createdAt     DateTime            @default(now())
  isActive      Boolean             @default(true)
  userId        String?
  user          User?               @relation(fields: [userId], references: [id])
  subscriptions MatchSubscription[]

  @@index([userId])
}

model MatchSubscription {
  id           String                 @id @default(uuid())
  subscriberId String
  fixtureId    Int
  homeTeam     String
  awayTeam     String
  leagueName   String?
  matchDate    DateTime
  subscriber   NotificationSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, fixtureId])
  @@index([fixtureId])
}

model EvolutionInstance {
  id           String   @id @default(uuid())
  instanceName String   @unique
  baseUrl      String
  apiKey       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── News ────────────────────────────────────────────────────────────────────

model News {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  summary     String?
  body        String
  imageUrl    String?
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id])
  publishedAt DateTime @default(now())
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@index([isDeleted, publishedAt])
}

// ─── Posts ───────────────────────────────────────────────────────────────────

model Post {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDeleted, createdAt])
}
