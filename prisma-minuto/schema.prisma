generator client {
  provider = "prisma-client"
  output   = "../prisma-minuto/minuto-client-types"
}

datasource db {
  provider = "postgresql"
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model NotificationSubscriber {
  id            String              @id @default(uuid())
  phoneNumber   String              @unique
  name          String?
  createdAt     DateTime            @default(now())
  isActive      Boolean             @default(true)
  subscriptions MatchSubscription[]
}

model MatchSubscription {
  id           String                 @id @default(uuid())
  subscriberId String
  fixtureId    Int
  homeTeam     String
  awayTeam     String
  leagueName   String?
  matchDate    DateTime
  subscriber   NotificationSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, fixtureId])
  @@index([fixtureId])
}

model EvolutionInstance {
  id           String   @id @default(uuid())
  instanceName String   @unique
  baseUrl      String
  apiKey       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
